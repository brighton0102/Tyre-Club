{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "index.storybook.ts",
    ".rnstorybook/main.ts",
    ".rnstorybook/preview.tsx",
    ".rnstorybook/index.ts"
  ],
  "exclude": [
    ".rnstorybook/storybook.requires.ts"
  ]
}
